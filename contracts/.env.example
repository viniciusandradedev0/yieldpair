# YieldPair — contracts/.env.example
#
# Copy this file to `contracts/.env` and fill in real values. The real `.env`
# (and `.env.local`) is already gitignored at the repo root — NEVER commit it.
#
# Usage (Sepolia deploy):
#   cd contracts && set -a && source .env && set +a
#   forge script script/Deploy.s.sol:Deploy --rpc-url sepolia --broadcast --verify -vvvv

# Alchemy (or any) Sepolia RPC endpoint URL. Referenced by `foundry.toml`
# as `rpc_endpoints.sepolia`.
ALCHEMY_SEPOLIA_URL=

# Deployer's private key (testnet only — fund via a Sepolia faucet). Read by
# script/Deploy.s.sol via vm.envUint("PRIVATE_KEY"). NEVER use a mainnet key here.
PRIVATE_KEY=

# Etherscan API key, used for `--verify` and referenced by `foundry.toml`
# as `etherscan.sepolia.key`.
ETHERSCAN_API_KEY=
