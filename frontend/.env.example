# Copy this file to .env.local and fill in real values for local development.
# NEVER commit .env or .env.local — they're gitignored.
#
# On Vercel (Passo 4.4) these are set as Project Environment Variables, not
# committed to the repo.

# WalletConnect Cloud project id (required for the WalletConnect connector —
# QR code / mobile wallets — inside RainbowKit). Get a free one at
# https://cloud.reown.com (formerly WalletConnect Cloud).
# Leaving this empty does NOT break the build/dev server; it only disables
# the WalletConnect connector until a real id is set.
VITE_WALLETCONNECT_PROJECT_ID=

# Optional custom Sepolia RPC URL (Alchemy/Infura/etc). If unset, wagmi falls
# back to a public Sepolia RPC, which is fine for light use but can rate-limit.
VITE_SEPOLIA_RPC_URL=
